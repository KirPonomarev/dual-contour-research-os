{
  "schema_version": "research-os.public-rootless-host-profile.v1",
  "profile_kind": "capability-requirements-only",
  "locators": [],
  "platform": {
    "kernel": "linux",
    "architecture": "x86_64",
    "container_platform": "linux/amd64"
  },
  "transport": {
    "selection": "operator-supplied-ssh-config-alias",
    "alias_pattern": "^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$",
    "batch_mode": true,
    "strict_host_key_checking": "yes",
    "password_authentication": false,
    "keyboard_interactive_authentication": false
  },
  "prerequisites": [
    "rootless-docker-user-socket",
    "enabled-rootless-docker-user-service",
    "user-systemd-manager",
    "user-lingering-enabled-before-login",
    "sha256sum",
    "install",
    "atomic-mv"
  ],
  "runtime_boundary": {
    "rootful_container_engine_allowed": false,
    "network": "none",
    "published_ports": [],
    "control_transport": "AF_UNIX",
    "external_action_authority": false
  },
  "operator_boundaries": {
    "automatic_sudo": false,
    "automatic_reboot": false,
    "domain_service_mutation": false,
    "public_listener_creation": false
  }
}
