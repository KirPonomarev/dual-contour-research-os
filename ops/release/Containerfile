FROM python@sha256:65a93d69fa75478d554f4ad27c85c1e69fa184956261b4301ebaf6dbb0a3543d

ARG RELEASE_SHA
LABEL org.opencontainers.image.title="Dual-Contour Research OS Bridge" \
      org.opencontainers.image.source="https://github.com/KirPonomarev/dual-contour-research-os" \
      org.opencontainers.image.revision="${RELEASE_SHA}"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONHASHSEED=0 \
    PYTHONPATH=/opt/research-os/src \
    PYTHONUNBUFFERED=1

RUN groupadd --gid 10001 research-os \
    && useradd --uid 10001 --gid 10001 --no-create-home --no-log-init --shell /usr/sbin/nologin research-os \
    && install -d -m 0700 -o 10001 -g 10001 /var/lib/research-os /run/research-os

WORKDIR /opt/research-os
COPY --chown=10001:10001 src/ /opt/research-os/src/
COPY --chown=10001:10001 contracts/catalog.json /opt/research-os/contracts/catalog.json
COPY --chown=10001:10001 contracts/a1/v1/ /opt/research-os/contracts/a1/v1/
COPY --chown=10001:10001 provenance/model-role-evaluation-v2.json /opt/research-os/provenance/model-role-evaluation-v2.json
COPY --chown=10001:10001 provenance/model-worker-ipc-extension-v1.json /opt/research-os/provenance/model-worker-ipc-extension-v1.json
COPY --chown=10001:10001 provenance/model-worker-ipc-extension-v2.json /opt/research-os/provenance/model-worker-ipc-extension-v2.json
COPY --chown=10001:10001 provenance/model-accounting-mode-v1.json /opt/research-os/provenance/model-accounting-mode-v1.json
COPY --chown=10001:10001 provenance/model-vacuous-output-reconciliation-v1.json /opt/research-os/provenance/model-vacuous-output-reconciliation-v1.json
COPY --chown=10001:10001 provenance/model-null-content-vacuous-reconciliation-v1.json /opt/research-os/provenance/model-null-content-vacuous-reconciliation-v1.json
COPY --chown=10001:10001 provenance/model-chief-null-content-vacuous-reconciliation-v1.json /opt/research-os/provenance/model-chief-null-content-vacuous-reconciliation-v1.json
COPY --chown=10001:10001 provenance/model-provider-routing-v1.json /opt/research-os/provenance/model-provider-routing-v1.json
COPY --chown=10001:10001 provenance/model-provider-routing-v2.json /opt/research-os/provenance/model-provider-routing-v2.json

USER 10001:10001
STOPSIGNAL SIGTERM
ENTRYPOINT ["python", "-m", "research_bridge.researchd"]
CMD ["--config", "/run/research-os/researchd.json"]
