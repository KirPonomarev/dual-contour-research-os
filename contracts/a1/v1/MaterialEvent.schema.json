{
  "$defs": {
    "non_empty_string": {
      "maxLength": 4096,
      "minLength": 1,
      "type": "string"
    },
    "resource_budget": {
      "additionalProperties": false,
      "properties": {
        "cost_units": {
          "minimum": 0,
          "type": "number"
        },
        "cpu_seconds": {
          "minimum": 1,
          "type": "integer"
        },
        "memory_mib": {
          "minimum": 64,
          "type": "integer"
        },
        "output_bytes": {
          "minimum": 1,
          "type": "integer"
        },
        "tokens": {
          "minimum": 0,
          "type": "integer"
        },
        "wall_seconds": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "wall_seconds",
        "cpu_seconds",
        "memory_mib",
        "output_bytes",
        "tokens",
        "cost_units"
      ],
      "type": "object"
    },
    "sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "string_array": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "vcs_identity": {
      "additionalProperties": false,
      "properties": {
        "a1_catalog_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "base_sha": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "contract_catalog_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "head_sha": {
          "pattern": "^[a-f0-9]{40}$",
          "type": "string"
        },
        "release_manifest_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "repository_id": {
          "minLength": 1,
          "type": "string"
        },
        "worktree_clean": {
          "const": true
        }
      },
      "required": [
        "repository_id",
        "head_sha",
        "base_sha",
        "worktree_clean",
        "contract_catalog_sha256",
        "a1_catalog_sha256",
        "release_manifest_sha256"
      ],
      "type": "object"
    }
  },
  "$id": "https://contracts.dual-contour.invalid/a1/v1/MaterialEvent.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0",
        "D1"
      ]
    },
    "contour": {
      "const": "bridge"
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "payload_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "profile_id": {
          "const": "core-json-sha256-v1"
        }
      },
      "required": [
        "profile_id",
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "const": "trusted-event-minter"
    },
    "object_id": {
      "maxLength": 256,
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "causal_depth": {
          "maximum": 32,
          "minimum": 0,
          "type": "integer"
        },
        "context_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "created_from_ledger_sequence": {
          "minimum": 0,
          "type": "integer"
        },
        "event_id": {
          "minLength": 1,
          "type": "string"
        },
        "event_kind": {
          "minLength": 1,
          "type": "string"
        },
        "evidence_refs": {
          "$ref": "#/$defs/string_array"
        },
        "materiality_inputs": {
          "additionalProperties": true,
          "minProperties": 1,
          "type": "object"
        },
        "origin_class": {
          "enum": [
            "EXOGENOUS",
            "ENDOGENOUS"
          ]
        },
        "origin_trigger_ref": {
          "minLength": 1,
          "type": "string"
        },
        "parent_event_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "policy_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "remaining_energy": {
          "$ref": "#/$defs/resource_budget"
        },
        "root_energy": {
          "$ref": "#/$defs/resource_budget"
        },
        "root_event_ref": {
          "minLength": 1,
          "type": "string"
        },
        "shadow_taint": {
          "enum": [
            "NONE",
            "SHADOW_UNAPPLIED"
          ]
        }
      },
      "required": [
        "event_id",
        "origin_class",
        "origin_trigger_ref",
        "event_kind",
        "root_event_ref",
        "parent_event_ref",
        "policy_sha256",
        "context_sha256",
        "root_energy",
        "remaining_energy",
        "causal_depth",
        "shadow_taint",
        "evidence_refs",
        "materiality_inputs",
        "created_from_ledger_sequence"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "MaterialEvent"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "MaterialEvent",
  "type": "object",
  "x-dual-contour": {
    "authority": "bounded-event",
    "catalog_status": "frozen",
    "core_catalog_sha256": "13bdac3a60227826550771635d7367854a8a5477240ed06b2c31198dbd6f5c50",
    "owner": "bridge",
    "writer": "trusted-event-minter"
  }
}
