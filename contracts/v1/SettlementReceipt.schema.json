{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/SettlementReceipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "actual_cost": {
          "minimum": 0,
          "type": "number"
        },
        "actual_usage": {
          "type": "object"
        },
        "ledger_version_after": {
          "minimum": 0,
          "type": "integer"
        },
        "provider_receipt_ref": {
          "minLength": 1,
          "type": "string"
        },
        "provider_unknown": {
          "type": "boolean"
        },
        "released_amount": {
          "minimum": 0,
          "type": "number"
        },
        "reservation_ref": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "reservation_ref",
        "actual_usage",
        "actual_cost",
        "provider_receipt_ref",
        "released_amount",
        "provider_unknown",
        "ledger_version_after"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "SettlementReceipt"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "SettlementReceipt",
  "type": "object",
  "x-authority": "budget-settlement",
  "x-owner": "bridge",
  "x-writer": "budget-ledger"
}
