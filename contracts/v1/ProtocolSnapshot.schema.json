{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/ProtocolSnapshot.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "code_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "environment_digest": {
          "minLength": 1,
          "type": "string"
        },
        "holdout_policy_ref": {
          "minLength": 1,
          "type": "string"
        },
        "hypothesis_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "input_manifest_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "primary_outcome": {
          "minLength": 1,
          "type": "string"
        },
        "seed_set": {
          "items": {
            "type": "integer"
          },
          "type": "array"
        },
        "stopping_rule": {
          "minLength": 1,
          "type": "string"
        },
        "trial_family_id": {
          "minLength": 1,
          "type": "string"
        },
        "validator_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "hypothesis_sha256",
        "primary_outcome",
        "input_manifest_sha256",
        "code_sha256",
        "environment_digest",
        "seed_set",
        "stopping_rule",
        "validator_sha256",
        "trial_family_id",
        "holdout_policy_ref"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "ProtocolSnapshot"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "ProtocolSnapshot",
  "type": "object",
  "x-authority": "scientific-protocol",
  "x-owner": "domain",
  "x-writer": "domain-registry-writer"
}
