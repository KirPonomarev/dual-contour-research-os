{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/ReplicationReceipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "child_trial_ref": {
          "minLength": 1,
          "type": "string"
        },
        "code_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "data_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "environment_digest": {
          "minLength": 1,
          "type": "string"
        },
        "independence_declaration": {
          "minLength": 1,
          "type": "string"
        },
        "metric_comparison": {
          "type": "object"
        },
        "original_outcome_ref": {
          "minLength": 1,
          "type": "string"
        },
        "parent_trial_ref": {
          "minLength": 1,
          "type": "string"
        },
        "replication_outcome_ref": {
          "minLength": 1,
          "type": "string"
        },
        "reproducibility_class": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "parent_trial_ref",
        "child_trial_ref",
        "independence_declaration",
        "data_sha256",
        "code_sha256",
        "environment_digest",
        "original_outcome_ref",
        "replication_outcome_ref",
        "metric_comparison",
        "reproducibility_class"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "ReplicationReceipt"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "ReplicationReceipt",
  "type": "object",
  "x-authority": "replication-result",
  "x-owner": "domain",
  "x-writer": "domain-registry-writer"
}
