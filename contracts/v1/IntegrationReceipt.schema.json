{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/IntegrationReceipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "agent_id": {
          "minLength": 1,
          "type": "string"
        },
        "audit_results": {
          "type": "object"
        },
        "base_sha": {
          "minLength": 1,
          "type": "string"
        },
        "contract_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "head_sha": {
          "minLength": 1,
          "type": "string"
        },
        "integration_commit_sha": {
          "minLength": 1,
          "type": "string"
        },
        "ownership_lease_ref": {
          "minLength": 1,
          "type": "string"
        },
        "remote_ci_ref": {
          "minLength": 1,
          "type": "string"
        },
        "stage_id": {
          "minLength": 1,
          "type": "string"
        },
        "write_set": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "stage_id",
        "agent_id",
        "ownership_lease_ref",
        "base_sha",
        "head_sha",
        "contract_sha256",
        "write_set",
        "audit_results",
        "remote_ci_ref",
        "integration_commit_sha"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "IntegrationReceipt"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "IntegrationReceipt",
  "type": "object",
  "x-authority": "accepted-stage",
  "x-owner": "governance",
  "x-writer": "agent-0"
}
