{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/ReuseDecisionReceipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "candidates": {
          "type": "array"
        },
        "canonical_owner": {
          "minLength": 1,
          "type": "string"
        },
        "capability": {
          "minLength": 1,
          "type": "string"
        },
        "code_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "license_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "license_spdx": {
          "minLength": 1,
          "type": "string"
        },
        "rollback": {
          "minLength": 1,
          "type": "string"
        },
        "selected_mode": {
          "minLength": 1,
          "type": "string"
        },
        "source_ref": {
          "minLength": 1,
          "type": "string"
        },
        "tests": {
          "type": "array"
        }
      },
      "required": [
        "capability",
        "candidates",
        "selected_mode",
        "source_ref",
        "code_sha256",
        "license_spdx",
        "license_sha256",
        "tests",
        "canonical_owner",
        "rollback"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "ReuseDecisionReceipt"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "ReuseDecisionReceipt",
  "type": "object",
  "x-authority": "reuse-freeze",
  "x-owner": "governance",
  "x-writer": "agent-0"
}
