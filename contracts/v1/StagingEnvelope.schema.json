{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/StagingEnvelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "minLength": 1,
          "type": "string"
        },
        "claimed_metrics": {
          "type": "object"
        },
        "completion_reason": {
          "minLength": 1,
          "type": "string"
        },
        "fencing_token": {
          "minLength": 1,
          "type": "string"
        },
        "producer_identity": {
          "minLength": 1,
          "type": "string"
        },
        "relative_file_manifest": {
          "type": "array"
        },
        "run_id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "producer_identity",
        "run_id",
        "attempt_id",
        "fencing_token",
        "relative_file_manifest",
        "claimed_metrics",
        "completion_reason"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "StagingEnvelope"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "StagingEnvelope",
  "type": "object",
  "x-authority": "untrusted-claim",
  "x-owner": "bridge",
  "x-writer": "untrusted-runner"
}
