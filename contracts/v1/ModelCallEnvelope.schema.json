{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/ModelCallEnvelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "idempotency_key": {
          "minLength": 1,
          "type": "string"
        },
        "max_cost": {
          "minimum": 0,
          "type": "number"
        },
        "max_tokens": {
          "minimum": 0,
          "type": "integer"
        },
        "prompt_template_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "protocol_ref": {
          "minLength": 1,
          "type": "string"
        },
        "provider_model_class": {
          "minLength": 1,
          "type": "string"
        },
        "redaction_receipt_ref": {
          "minLength": 1,
          "type": "string"
        },
        "role": {
          "minLength": 1,
          "type": "string"
        },
        "sanitized_input_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "role",
        "protocol_ref",
        "prompt_template_sha256",
        "sanitized_input_refs",
        "redaction_receipt_ref",
        "provider_model_class",
        "max_tokens",
        "max_cost",
        "idempotency_key"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "ModelCallEnvelope"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "ModelCallEnvelope",
  "type": "object",
  "x-authority": "budgeted-request",
  "x-owner": "bridge",
  "x-writer": "model-broker"
}
