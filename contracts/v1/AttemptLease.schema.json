{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/AttemptLease.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "minLength": 1,
          "type": "string"
        },
        "checkpoint_parent_ref": {
          "minLength": 1,
          "type": "string"
        },
        "expires_at": {
          "minLength": 1,
          "type": "string"
        },
        "fencing_epoch": {
          "minimum": 0,
          "type": "integer"
        },
        "fencing_token": {
          "minLength": 1,
          "type": "string"
        },
        "issued_at": {
          "minLength": 1,
          "type": "string"
        },
        "job_ref": {
          "minLength": 1,
          "type": "string"
        },
        "permit_ref": {
          "minLength": 1,
          "type": "string"
        },
        "runner_identity": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "attempt_id",
        "permit_ref",
        "job_ref",
        "runner_identity",
        "fencing_epoch",
        "fencing_token",
        "issued_at",
        "expires_at",
        "checkpoint_parent_ref"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "AttemptLease"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "AttemptLease",
  "type": "object",
  "x-authority": "single-attempt-lease",
  "x-owner": "bridge",
  "x-writer": "researchd"
}
