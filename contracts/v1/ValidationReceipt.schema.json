{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/ValidationReceipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "artifact_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "checks_performed": {
          "type": "array"
        },
        "execution_ref": {
          "minLength": 1,
          "type": "string"
        },
        "holdout_access_ref": {
          "minLength": 1,
          "type": "string"
        },
        "metrics": {
          "type": "object"
        },
        "proposed_outcome": {
          "minLength": 1,
          "type": "string"
        },
        "protocol_ref": {
          "minLength": 1,
          "type": "string"
        },
        "reasons": {
          "type": "array"
        },
        "reproducibility_class": {
          "minLength": 1,
          "type": "string"
        },
        "tolerances": {
          "type": "object"
        },
        "validator_id": {
          "minLength": 1,
          "type": "string"
        },
        "validator_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "protocol_ref",
        "execution_ref",
        "artifact_refs",
        "validator_id",
        "validator_sha256",
        "holdout_access_ref",
        "checks_performed",
        "metrics",
        "tolerances",
        "proposed_outcome",
        "reasons",
        "reproducibility_class"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "ValidationReceipt"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "ValidationReceipt",
  "type": "object",
  "x-authority": "proposed-outcome-only",
  "x-owner": "domain",
  "x-writer": "pinned-validator"
}
