{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/DomainTrialLinkReceipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "applied_outcome_ref": {
          "minLength": 1,
          "type": "string"
        },
        "bridge_execution_ref": {
          "minLength": 1,
          "type": "string"
        },
        "domain_trial_id": {
          "minLength": 1,
          "type": "string"
        },
        "policy_ref": {
          "minLength": 1,
          "type": "string"
        },
        "protocol_ref": {
          "minLength": 1,
          "type": "string"
        },
        "registry_identity": {
          "minLength": 1,
          "type": "string"
        },
        "registry_revision": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "domain_trial_id",
        "bridge_execution_ref",
        "protocol_ref",
        "registry_identity",
        "registry_revision",
        "applied_outcome_ref",
        "policy_ref"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "DomainTrialLinkReceipt"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "DomainTrialLinkReceipt",
  "type": "object",
  "x-authority": "canonical-domain-link",
  "x-owner": "domain",
  "x-writer": "domain-registry-writer"
}
