{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/Permit.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "code_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "expires_at": {
          "minLength": 1,
          "type": "string"
        },
        "image_digest": {
          "minLength": 1,
          "type": "string"
        },
        "input_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "job_spec_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "max_uses": {
          "minimum": 0,
          "type": "integer"
        },
        "network_class": {
          "minLength": 1,
          "type": "string"
        },
        "nonce": {
          "minLength": 1,
          "type": "string"
        },
        "not_before": {
          "minLength": 1,
          "type": "string"
        },
        "policy_snapshot_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "quotas": {
          "type": "object"
        },
        "subject": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "subject",
        "job_spec_sha256",
        "policy_snapshot_sha256",
        "code_sha256",
        "input_sha256",
        "image_digest",
        "quotas",
        "network_class",
        "not_before",
        "expires_at",
        "max_uses",
        "nonce"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "Permit"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "Permit",
  "type": "object",
  "x-authority": "execution-authority",
  "x-owner": "governance",
  "x-writer": "permit-authority"
}
