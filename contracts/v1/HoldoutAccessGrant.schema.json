{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/HoldoutAccessGrant.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "accessor_identity": {
          "minLength": 1,
          "type": "string"
        },
        "allowed_operation": {
          "minLength": 1,
          "type": "string"
        },
        "expires_at": {
          "minLength": 1,
          "type": "string"
        },
        "not_before": {
          "minLength": 1,
          "type": "string"
        },
        "protocol_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "query_limits": {
          "type": "object"
        },
        "single_use_nonce": {
          "minLength": 1,
          "type": "string"
        },
        "trial_ref": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "trial_ref",
        "protocol_sha256",
        "accessor_identity",
        "allowed_operation",
        "query_limits",
        "not_before",
        "expires_at",
        "single_use_nonce"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "HoldoutAccessGrant"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "HoldoutAccessGrant",
  "type": "object",
  "x-authority": "single-use-holdout-access",
  "x-owner": "domain",
  "x-writer": "holdout-owner"
}
