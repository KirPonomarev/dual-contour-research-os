{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/SourceFreezeReceipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "branch": {
          "minLength": 1,
          "type": "string"
        },
        "head_sha": {
          "minLength": 1,
          "type": "string"
        },
        "path_dispositions": {
          "type": "array"
        },
        "remote": {
          "minLength": 1,
          "type": "string"
        },
        "selected_source_sha": {
          "minLength": 1,
          "type": "string"
        },
        "source_repo": {
          "minLength": 1,
          "type": "string"
        },
        "tracked_diff_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "untracked_manifest_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "upstream_sha": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "source_repo",
        "remote",
        "branch",
        "head_sha",
        "upstream_sha",
        "tracked_diff_sha256",
        "untracked_manifest_sha256",
        "path_dispositions",
        "selected_source_sha"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "SourceFreezeReceipt"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "SourceFreezeReceipt",
  "type": "object",
  "x-authority": "source-freeze",
  "x-owner": "governance",
  "x-writer": "agent-0"
}
