{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/ExecutionReceipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "artifact_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "code_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "ended_at": {
          "minLength": 1,
          "type": "string"
        },
        "environment_digest": {
          "minLength": 1,
          "type": "string"
        },
        "event_chain_head": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "exit_classification": {
          "minLength": 1,
          "type": "string"
        },
        "input_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "job_spec_ref": {
          "minLength": 1,
          "type": "string"
        },
        "lease_ref": {
          "minLength": 1,
          "type": "string"
        },
        "permit_ref": {
          "minLength": 1,
          "type": "string"
        },
        "resource_usage": {
          "type": "object"
        },
        "started_at": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "permit_ref",
        "lease_ref",
        "job_spec_ref",
        "code_sha256",
        "input_sha256",
        "environment_digest",
        "started_at",
        "ended_at",
        "exit_classification",
        "artifact_refs",
        "resource_usage",
        "event_chain_head"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "ExecutionReceipt"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "ExecutionReceipt",
  "type": "object",
  "x-authority": "mechanical-result",
  "x-owner": "bridge",
  "x-writer": "researchd"
}
