{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/PolicySnapshot.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "aggregate_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "allow_rules": {
          "type": "array"
        },
        "commit_sha": {
          "minLength": 1,
          "type": "string"
        },
        "covered_action_classes": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "deny_rules": {
          "type": "array"
        },
        "source_repo": {
          "minLength": 1,
          "type": "string"
        },
        "valid_from": {
          "minLength": 1,
          "type": "string"
        },
        "valid_until": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "source_repo",
        "commit_sha",
        "aggregate_sha256",
        "covered_action_classes",
        "allow_rules",
        "deny_rules",
        "valid_from",
        "valid_until"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "PolicySnapshot"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "PolicySnapshot",
  "type": "object",
  "x-authority": "policy",
  "x-owner": "governance",
  "x-writer": "policy-authority"
}
