{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/HypothesisCard.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "falsification_rule": {
          "minLength": 1,
          "type": "string"
        },
        "hypothesis_id": {
          "minLength": 1,
          "type": "string"
        },
        "mechanism": {
          "minLength": 1,
          "type": "string"
        },
        "null_hypothesis": {
          "minLength": 1,
          "type": "string"
        },
        "scope_boundary": {
          "minLength": 1,
          "type": "string"
        },
        "source_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "thesis": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "hypothesis_id",
        "thesis",
        "null_hypothesis",
        "mechanism",
        "falsification_rule",
        "scope_boundary",
        "source_refs"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "HypothesisCard"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "HypothesisCard",
  "type": "object",
  "x-authority": "proposal",
  "x-owner": "domain",
  "x-writer": "domain-adapter"
}
