{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/DeploymentApprovalReceipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "config_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "environment": {
          "minLength": 1,
          "type": "string"
        },
        "expires_at": {
          "minLength": 1,
          "type": "string"
        },
        "image_digest": {
          "minLength": 1,
          "type": "string"
        },
        "nonce": {
          "minLength": 1,
          "type": "string"
        },
        "policy_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "release_sha": {
          "minLength": 1,
          "type": "string"
        },
        "remote_ci_ref": {
          "minLength": 1,
          "type": "string"
        },
        "restore_receipt_ref": {
          "minLength": 1,
          "type": "string"
        },
        "rollback_target": {
          "minLength": 1,
          "type": "string"
        },
        "schema_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "environment",
        "release_sha",
        "image_digest",
        "policy_sha256",
        "config_sha256",
        "schema_sha256",
        "remote_ci_ref",
        "restore_receipt_ref",
        "rollback_target",
        "expires_at",
        "nonce"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "DeploymentApprovalReceipt"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "DeploymentApprovalReceipt",
  "type": "object",
  "x-authority": "deployment-approval",
  "x-owner": "governance",
  "x-writer": "operator-authority"
}
