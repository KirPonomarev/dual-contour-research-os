{
  "$id": "https://github.com/KirPonomarev/dual-contour-research-os/contracts/v1/ArtifactManifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "classification": {
      "enum": [
        "D0_PUBLIC",
        "D1_INTERNAL_SANITIZED",
        "D2_DOMAIN_CONFIDENTIAL",
        "D3_RESTRICTED"
      ]
    },
    "contour": {
      "enum": [
        "bridge",
        "market",
        "security",
        "governance"
      ]
    },
    "integrity": {
      "additionalProperties": false,
      "properties": {
        "parent_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "payload_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        }
      },
      "required": [
        "payload_sha256",
        "parent_refs"
      ],
      "type": "object"
    },
    "issued_at": {
      "format": "date-time",
      "type": "string"
    },
    "issuer": {
      "additionalProperties": false,
      "properties": {
        "authority_class": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "authority_class"
      ],
      "type": "object"
    },
    "object_id": {
      "minLength": 1,
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "artifact_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "claim_class": {
          "minLength": 1,
          "type": "string"
        },
        "producer": {
          "minLength": 1,
          "type": "string"
        },
        "redaction_status": {
          "minLength": 1,
          "type": "string"
        },
        "retention_class": {
          "minLength": 1,
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "type": "integer"
        },
        "source_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "validator_ref": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "artifact_sha256",
        "size_bytes",
        "producer",
        "claim_class",
        "source_refs",
        "redaction_status",
        "retention_class",
        "validator_ref"
      ],
      "type": "object"
    },
    "schema_id": {
      "const": "ArtifactManifest"
    },
    "schema_version": {
      "const": "1.0.0"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "object_id",
    "issued_at",
    "issuer",
    "contour",
    "classification",
    "payload",
    "integrity"
  ],
  "title": "ArtifactManifest",
  "type": "object",
  "x-authority": "artifact-reference",
  "x-owner": "domain",
  "x-writer": "trusted-ingestor"
}
