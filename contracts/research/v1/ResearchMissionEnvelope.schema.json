{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dual-contour-research-os.invalid/contracts/research/v1/ResearchMissionEnvelope.schema.json",
  "title": "ResearchMissionEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "object_id", "issued_at", "payload", "integrity"],
  "properties": {
    "schema_id": {"const": "ResearchMissionEnvelope"},
    "schema_version": {"const": "1.0.0"},
    "object_id": {"type": "string", "pattern": "^research-mission:[a-f0-9]{64}$"},
    "issued_at": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_sha256", "plan_sha256", "artifact_ref", "artifact_sha256",
        "prepared_kimi_request_ref", "prepared_kimi_request_sha256",
        "artifact_size_bytes", "artifact_schema_id", "data_class",
        "project_fingerprints", "runtime_heads", "domain_binding_sha256s",
        "paired_execution_id", "expected_trigger_domains", "provider_boundary",
        "expires_at", "stop_conditions", "rollback", "forbidden_boundaries",
        "live_authority", "domain_write_authority", "canonical_write_authority"
      ],
      "properties": {
        "mission_sha256": {"$ref": "#/$defs/sha256"},
        "plan_sha256": {"$ref": "#/$defs/sha256"},
        "artifact_ref": {"type": "string", "pattern": "^cas:sha256:[a-f0-9]{64}$"},
        "artifact_sha256": {"$ref": "#/$defs/sha256"},
        "prepared_kimi_request_ref": {"type": "string", "pattern": "^cas:sha256:[a-f0-9]{64}$"},
        "prepared_kimi_request_sha256": {"$ref": "#/$defs/sha256"},
        "artifact_size_bytes": {"type": "integer", "minimum": 1, "maximum": 131072},
        "artifact_schema_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "data_class": {"enum": ["D0_PUBLIC", "D1_INTERNAL_SANITIZED"]},
        "project_fingerprints": {"$ref": "#/$defs/threeShaMap"},
        "runtime_heads": {"$ref": "#/$defs/threeGitMap"},
        "domain_binding_sha256s": {"$ref": "#/$defs/twoShaMap"},
        "paired_execution_id": {"type": "string", "pattern": "^paired-research-ingress:[a-f0-9]{64}$"},
        "expected_trigger_domains": {"const": ["market", "security"]},
        "provider_boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["roles", "bindings", "reasoning_efforts", "maximum_calls", "maximum_calls_per_role", "fallback_allowed"],
          "properties": {
            "roles": {"const": ["SCOUT_FAST", "RESEARCH_WORKER", "CRITIC_PRIMARY", "CRITIC_DEEP", "CHIEF_SCIENTIST"]},
            "bindings": {"const": ["deepseek-v4-flash", "deepseek-v4-pro", "kimi-k3-max", "gpt-5.6-sol-xhigh", "gpt-5.6-sol-xhigh"]},
            "reasoning_efforts": {"const": ["max", "max", "max", "xhigh", "xhigh"]},
            "maximum_calls": {"const": 5},
            "maximum_calls_per_role": {"const": 1},
            "fallback_allowed": {"const": false}
          }
        },
        "expires_at": {"type": "string", "format": "date-time"},
        "stop_conditions": {"$ref": "#/$defs/nonemptyStrings"},
        "rollback": {"type": "string", "minLength": 1, "maxLength": 2048},
        "forbidden_boundaries": {"$ref": "#/$defs/nonemptyStrings"},
        "live_authority": {"const": false},
        "domain_write_authority": {"const": false},
        "canonical_write_authority": {"const": false}
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payload_sha256"],
      "properties": {"payload_sha256": {"$ref": "#/$defs/sha256"}}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "gitSha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "nonemptyStrings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 512}},
    "threeShaMap": {"type": "object", "additionalProperties": false, "required": ["bridge", "market", "security"], "properties": {"bridge": {"$ref": "#/$defs/sha256"}, "market": {"$ref": "#/$defs/sha256"}, "security": {"$ref": "#/$defs/sha256"}}},
    "threeGitMap": {"type": "object", "additionalProperties": false, "required": ["bridge", "market", "security"], "properties": {"bridge": {"$ref": "#/$defs/gitSha"}, "market": {"$ref": "#/$defs/gitSha"}, "security": {"$ref": "#/$defs/gitSha"}}},
    "twoShaMap": {"type": "object", "additionalProperties": false, "required": ["market", "security"], "properties": {"market": {"$ref": "#/$defs/sha256"}, "security": {"$ref": "#/$defs/sha256"}}}
  }
}
